# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - track CLAUDE.md and memory/ for all registered groups
# Excludes conversations, logs, and sensitive runtime data
groups/*
!groups/main/
!groups/global/
!groups/whatsapp_main/
groups/main/*
groups/global/*
groups/whatsapp_main/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md
!groups/whatsapp_main/CLAUDE.md
!groups/main/memory/
!groups/global/memory/
!groups/whatsapp_main/memory/
groups/main/memory/*
groups/global/memory/*
groups/whatsapp_main/memory/*
!groups/main/memory/*.md
!groups/global/memory/*.md
!groups/whatsapp_main/memory/*.md

# State dirs — track the directory but not transient task JSON files
!groups/main/state/
!groups/whatsapp_main/state/
groups/main/state/*
groups/whatsapp_main/state/*
!groups/main/state/.gitkeep
!groups/whatsapp_main/state/.gitkeep

# Secrets
*.keys.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
